# ══════════════════════════════════════════════════════════════
# PFE Data Platform — Variables d'environnement (TEMPLATE)
# Copier ce fichier en .env et remplacer les valeurs par défaut
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ─── PostgreSQL Source (OLTP) ─────────────────────────────────
POSTGRES_SOURCE_HOST=postgres_source
POSTGRES_SOURCE_PORT=5432
POSTGRES_SOURCE_USER=<your_db_user>
POSTGRES_SOURCE_PASSWORD=<your_db_password>
POSTGRES_SOURCE_DB=<your_oltp_db_name>

# ─── PostgreSQL DWH (Bronze / Silver / Gold) ─────────────────
POSTGRES_DWH_HOST=postgres_dwh
POSTGRES_DWH_PORT=5432
POSTGRES_DWH_USER=<your_dwh_user>
POSTGRES_DWH_PASSWORD=<your_dwh_password>
POSTGRES_DWH_DB=<your_dwh_db_name>

# ─── PostgreSQL Infra (Airflow metadata) ─────────────────────
POSTGRES_INFRA_USER=<your_infra_user>
POSTGRES_INFRA_PASSWORD=<your_infra_password>
POSTGRES_INFRA_DB=<your_infra_db_name>

# ─── Apache Airflow ──────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<user>:<password>@postgres_infra:5432/<db>
AIRFLOW__CORE__FERNET_KEY=<your_fernet_key>
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW_ADMIN_USER=<your_airflow_admin>
AIRFLOW_ADMIN_PASSWORD=<your_airflow_password>

# ─── Apache Beam ─────────────────────────────────────────────
BEAM_RUNNER=DirectRunner

# ─── FastAPI Mock ────────────────────────────────────────────
FASTAPI_MOCK_HOST=fastapi-mock
FASTAPI_MOCK_PORT=80

# ─── Grafana ─────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=<your_grafana_user>
GF_SECURITY_ADMIN_PASSWORD=<your_grafana_password>

# ─── pgAdmin ────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=<your_email@example.com>
PGADMIN_DEFAULT_PASSWORD=<your_pgadmin_password>

# ─── DuckDB ──────────────────────────────────────────────────
DUCKDB_DATABASE_PATH=data/processed/warehouse.duckdb

# ─── Kaggle API ──────────────────────────────────────────────
KAGGLE_USERNAME=<your_kaggle_username>
KAGGLE_KEY=<your_kaggle_api_key>
